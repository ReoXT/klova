# URL of your Express backend.
# Locally: http://localhost:4000
# Production: your Railway deployment URL (e.g. https://klova-api.up.railway.app)
NEXT_PUBLIC_API_URL=https://klova-production.up.railway.app
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Resend API key for sending transactional emails (web/emails/). A separate
# key from whatever is configured as Supabase Auth's custom SMTP password.
RESEND_API_KEY=

# Shared secret required on POST /api/internal/notify-keeper (checked against
# the X-Internal-Secret header). Lets the Express api/ backend trigger keeper
# emails for events it owns (new job assigned, withdrawal paid/failed) without
# duplicating the templates, which live only here in web/emails/. Must match
# api/'s INTERNAL_NOTIFY_SECRET exactly. Generate with: openssl rand -hex 32
INTERNAL_NOTIFY_SECRET=

# OpenRouteService API key — used server-side to geocode cleaner addresses in
# the admin panel and for transport-fare calculation. Free tier at
# https://openrouteservice.org (sign up → Tokens). Driving-distance calculation
# stays on ORS; address search for customers is moving to Google (see below).
ORS_API_KEY=

# Google Maps Platform API key — used server-side for customer-facing address
# autocomplete (Places API New, session-based) and geocoding.
# Restrict this key in Google Cloud Console to:
#   APIs:    Places API (New), Geocoding API
#   Domains: klova-nine.vercel.app/*, localhost:3000/*
# Never expose this in NEXT_PUBLIC_ — always proxy through a server route.
# Free tier: $200/month credit (~11,700 Autocomplete sessions, ~40,000 geocodes).
# Pricing: https://cloud.google.com/maps-platform/pricing
GOOGLE_MAPS_API_KEY=
