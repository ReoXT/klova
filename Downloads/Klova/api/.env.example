# ─── Server ───────────────────────────────────────────────
PORT=4000

# ─── Supabase (Postgres + auth) ───────────────────────────
# Found in: Supabase dashboard → Project Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Service role key — server only, NEVER send this to the frontend or commit it
SUPABASE_SERVICE_ROLE_KEY=

# ─── Paystack (payments) ──────────────────────────────────
# Found in: Paystack dashboard → Settings → API Keys & Webhooks
# Webhook signatures are verified using PAYSTACK_SECRET_KEY directly (Paystack uses
# the same key for both API calls and HMAC-SHA512 webhook signature verification).
# No separate webhook secret is needed.
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# ─── Termii (SMS / WhatsApp notifications) ────────────────
# Found in: Termii dashboard → Settings → API
TERMII_API_KEY=
TERMII_SENDER_ID=
# Nigerian number to receive a confirmation SMS per paid booking (e.g. 08012345678)
ADMIN_PHONE=

# ─── Klova settings ───────────────────────────────────────
# Commission percentage taken from each booking (0.22 = 22%)
COMMISSION_RATE=0.22
# Static bearer token for /admin/* routes — generate with: openssl rand -hex 32
ADMIN_API_KEY=
# Maximum transport fare (NGN) accepted without rejection as a fat-finger. Default: 5000.
TRANSPORT_FARE_CEILING_NGN=5000
# Hours after quoting transport before a booking shows as overdue in the admin cockpit.
# Hard deadline is always the booking date itself — whichever comes first governs.
TRANSPORT_PAYMENT_DEADLINE_HOURS=24

# ─── CORS ─────────────────────────────────────────────────
# The frontend origin allowed to call this API.
# Locally: http://localhost:3000
# Production: your Vercel URL (e.g. https://klova.vercel.app)
FRONTEND_ORIGIN=
